# Nvidia Dockerfiles: https://github.com/NVIDIA-Omniverse/IsaacSim-dockerfiles
# Please check above link for license information.

# Base image
ARG ISAACSIM_BASE_IMAGE_ARG
ARG ISAACSIM_VERSION_ARG
FROM ${ISAACSIM_BASE_IMAGE_ARG}:${ISAACSIM_VERSION_ARG} AS base
ENV ISAACSIM_VERSION=${ISAACSIM_VERSION_ARG}

# Set default RUN shell to bash
SHELL ["/bin/bash", "-c"]

# Adds labels to the Dockerfile
LABEL version="2.3.2"
LABEL description="Dockerfile for building and running Isaac Lab (repo install method) inside Isaac Sim container image."

# Arguments
# Path to Isaac Sim root folder
ARG ISAACSIM_ROOT_PATH_ARG
ENV ISAACSIM_ROOT_PATH=${ISAACSIM_ROOT_PATH_ARG}
# Workspace path inside the container (IsaacLab-Imitation root)
ARG ISAACLAB_PATH_ARG
ENV ISAACLAB_PATH=${ISAACLAB_PATH_ARG}
# Home dir of docker user, typically '/root'
ARG DOCKER_USER_HOME_ARG
ENV DOCKER_USER_HOME=${DOCKER_USER_HOME_ARG}

# Isaac Lab core repository path in the workspace
ENV ISAACLAB_CORE_PATH=${ISAACLAB_PATH}/IsaacLab

# Default Unitree asset locations
ENV UNITREE_MODEL_DIR=${ISAACLAB_PATH}/unitree_model
ENV UNITREE_ROS_DIR=${ISAACLAB_PATH}/unitree_ros

# Set environment variables
ENV LANG=C.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

USER root

# Install dependencies and remove cache
RUN --mount=type=cache,target=/var/cache/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    git-lfs \
    libglib2.0-0 \
    ncurses-term \
    wget \
    ca-certificates && \
    git lfs install --system && \
    apt -y autoremove && apt clean autoclean && \
    rm -rf /var/lib/apt/lists/*

# Copy workspace repositories into one stable layout.
# - ISAACLAB_PATH: IsaacLab-Imitation repo
# - ISAACLAB_CORE_PATH: IsaacLab core repo
COPY ../ ${ISAACLAB_PATH}
COPY --from=isaaclab / ${ISAACLAB_CORE_PATH}
COPY --from=unitree_rl_lab / ${ISAACLAB_PATH}/unitree_rl_lab
RUN mkdir -p ${ISAACLAB_PATH}/unitree_model
COPY --from=unitree_model /B2 ${ISAACLAB_PATH}/unitree_model/B2
COPY --from=unitree_model /G1 ${ISAACLAB_PATH}/unitree_model/G1
COPY --from=unitree_model /Go2 ${ISAACLAB_PATH}/unitree_model/Go2
COPY --from=unitree_model /Go2W ${ISAACLAB_PATH}/unitree_model/Go2W
COPY --from=unitree_model /H1 ${ISAACLAB_PATH}/unitree_model/H1
COPY --from=unitree_model /H1-2 ${ISAACLAB_PATH}/unitree_model/H1-2
COPY --from=unitree_model /README.md ${ISAACLAB_PATH}/unitree_model/README.md

# Old IsaacLab installation strategy.
RUN chmod +x ${ISAACLAB_CORE_PATH}/isaaclab.sh
RUN ln -sf ${ISAACSIM_ROOT_PATH} ${ISAACLAB_CORE_PATH}/_isaac_sim
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -m pip install toml
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -c "import toml; print('Verified Python package: toml')"

# Install apt dependencies for IsaacLab core and local extension sources.
RUN --mount=type=cache,target=/var/cache/apt \
    ${ISAACLAB_CORE_PATH}/isaaclab.sh -p ${ISAACLAB_CORE_PATH}/tools/install_deps.py apt \
    ${ISAACLAB_CORE_PATH}/source \
    && \
    ${ISAACLAB_CORE_PATH}/isaaclab.sh -p ${ISAACLAB_CORE_PATH}/tools/install_deps.py apt \
    ${ISAACLAB_PATH}/source \
    && \
    ${ISAACLAB_CORE_PATH}/isaaclab.sh -p ${ISAACLAB_CORE_PATH}/tools/install_deps.py apt \
    ${ISAACLAB_PATH}/unitree_rl_lab/source \
    && \
    apt -y autoremove && apt clean autoclean && \
    rm -rf /var/lib/apt/lists/*

# Install IsaacLab dependencies using the repository installer.
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -m pip install --upgrade pip
RUN --mount=type=cache,target=${DOCKER_USER_HOME}/.cache/pip \
    ${ISAACLAB_CORE_PATH}/isaaclab.sh --install
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -c "from importlib import metadata; packages=['isaaclab','isaaclab_tasks','isaaclab_assets','isaaclab_rl','isaaclab_mimic']; versions={name: metadata.version(name) for name in packages}; print('Verified installed IsaacLab packages:', versions)"

# Install local extension packages.
RUN --mount=type=cache,target=${DOCKER_USER_HOME}/.cache/pip \
    ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -m pip install \
    -e ${ISAACLAB_PATH}/source/isaaclab_imitation \
    -e ${ISAACLAB_PATH}/unitree_rl_lab/source/unitree_rl_lab
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -c "from importlib import metadata; packages=['isaaclab_imitation','unitree_rl_lab']; versions={name: metadata.version(name) for name in packages}; print('Verified installed local packages:', versions)"
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -c "from pathlib import Path; root=Path('${UNITREE_MODEL_DIR}'); required=['B2','G1','Go2','Go2W','H1','H1-2']; missing=[name for name in required if not (root / name).exists()]; assert not missing, f'Missing Unitree model directories: {missing}'; print('Verified Unitree model directories:', ', '.join(required))"

# Keep optional dependency behavior aligned with prior image.
RUN ${ISAACLAB_CORE_PATH}/isaaclab.sh -p -m pip uninstall -y quadprog || true

# For singularity usage, create directories that will be bind-mounted.
RUN mkdir -p ${ISAACSIM_ROOT_PATH}/kit/cache && \
    mkdir -p ${DOCKER_USER_HOME}/.cache/ov && \
    mkdir -p ${DOCKER_USER_HOME}/.cache/pip && \
    mkdir -p ${DOCKER_USER_HOME}/.cache/nvidia/GLCache && \
    mkdir -p ${DOCKER_USER_HOME}/.nv/ComputeCache && \
    mkdir -p ${DOCKER_USER_HOME}/.nvidia-omniverse/logs && \
    mkdir -p ${DOCKER_USER_HOME}/.local/share/ov/data && \
    mkdir -p ${DOCKER_USER_HOME}/Documents

# For singularity usage, create NVIDIA binary placeholders.
RUN touch /bin/nvidia-smi && \
    touch /bin/nvidia-debugdump && \
    touch /bin/nvidia-persistenced && \
    touch /bin/nvidia-cuda-mps-control && \
    touch /bin/nvidia-cuda-mps-server && \
    touch /etc/localtime && \
    mkdir -p /var/run/nvidia-persistenced && \
    touch /var/run/nvidia-persistenced/socket

# Aliases and environment setup for interactive shells.
RUN echo "export ISAACLAB_WORKSPACE_PATH=${ISAACLAB_PATH}" >> ${HOME}/.bashrc && \
    echo "export ISAACLAB_PATH=${ISAACLAB_CORE_PATH}" >> ${HOME}/.bashrc && \
    echo "export UNITREE_MODEL_DIR=${UNITREE_MODEL_DIR}" >> ${HOME}/.bashrc && \
    echo "export UNITREE_ROS_DIR=${UNITREE_ROS_DIR}" >> ${HOME}/.bashrc && \
    echo "alias isaaclab=${ISAACLAB_CORE_PATH}/isaaclab.sh" >> ${HOME}/.bashrc && \
    echo "alias python=${ISAACLAB_CORE_PATH}/_isaac_sim/python.sh" >> ${HOME}/.bashrc && \
    echo "alias python3=${ISAACLAB_CORE_PATH}/_isaac_sim/python.sh" >> ${HOME}/.bashrc && \
    echo "alias pip='${ISAACLAB_CORE_PATH}/_isaac_sim/python.sh -m pip'" >> ${HOME}/.bashrc && \
    echo "alias pip3='${ISAACLAB_CORE_PATH}/_isaac_sim/python.sh -m pip'" >> ${HOME}/.bashrc && \
    echo "alias tensorboard='${ISAACLAB_CORE_PATH}/_isaac_sim/python.sh ${ISAACLAB_CORE_PATH}/_isaac_sim/tensorboard'" >> ${HOME}/.bashrc && \
    echo "export TZ=$(date +%Z)" >> ${HOME}/.bashrc && \
    echo "shopt -s histappend" >> /root/.bashrc && \
    echo "PROMPT_COMMAND='history -a'" >> /root/.bashrc

# Make working directory as the workspace root.
WORKDIR ${ISAACLAB_PATH}
